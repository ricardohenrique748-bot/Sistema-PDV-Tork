DATABASE_URL="postgresql://tork_user:tork_pass@localhost:5432/torkdb"
JWT_SECRET="TROQUE-ESTA-CHAVE-JWT-SUPER-SECRETA-MINIMO-32-CARACTERES"
JWT_REFRESH_SECRET="TROQUE-ESTA-CHAVE-REFRESH-JWT-SUPER-SECRETA-DIFERENTE"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# Chave de criptografia AES-256 para o certificado digital (32 bytes = 64 chars hex)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CERT_ENCRYPTION_KEY="GERE-UMA-CHAVE-HEX-DE-64-CARACTERES-AQUI"

# Redis
REDIS_URL="redis://localhost:6379"

# Porta do servidor
PORT=3001
NODE_ENV=development

# Focus NF-e API (cadastre-se em https://app.focusnfe.com.br)
FOCUS_NFE_TOKEN="seu-token-focus-nfe-aqui"
FOCUS_NFE_BASE_URL="https://homologacao.focusnfe.com.br/v2"
# Producao: https://api.focusnfe.com.br/v2

# CNPJ da empresa emitente
EMPRESA_CNPJ="00000000000000"

# URL base do frontend (para CORS)
FRONTEND_URL="http://localhost:5173"

# URL publica para webhook da Focus NF-e (use ngrok em desenvolvimento)
WEBHOOK_URL="https://seu-dominio.com/api/webhooks/focus"

# Diretorios de upload
UPLOAD_DIR="./uploads"
MAX_CERT_SIZE_MB=5
